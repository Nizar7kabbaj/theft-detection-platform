# Secrets - NEVER bake these into images
.env
.env.*
*.pem
*.key

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments (must NEVER end up in image)
venv/
env/
.venv/

# IDE / editor
.vscode/
.idea/
*.swp

# OS junk
.DS_Store
Thumbs.db

# Build artifacts
*.egg-info/
dist/
build/

# Git
.git/
.gitignore

# Docker itself
Dockerfile
.dockerignore